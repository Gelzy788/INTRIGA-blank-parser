<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768.0" prefWidth="1024.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="top-navbar" BorderPane.alignment="CENTER">
            <padding><Insets bottom="10.0" left="20.0" right="20.0" top="10.0" /></padding>
            <ImageView fitHeight="54.0" fitWidth="54.0" pickOnBounds="true" preserveRatio="true">
                <image><Image url="@media/logo.png" /></image>
            </ImageView>
            <Label styleClass="brand-title" text="INTRIGA" />
            
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="icon-label" text="👤" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="220.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
            
            <Label styleClass="version-text" text="v1.0.42" />
            
            <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                <padding><Insets top="30.0" /></padding>
                <Button fx:id="btnQueue" mnemonicParsing="false" styleClass="menu-button, menu-item-active" text="🏠 Main" />
                <Button fx:id="btnSettings" mnemonicParsing="false" styleClass="menu-button" text="⚙ Settings" />
            </VBox>
        </VBox>
    </left>

    <center>
        <BorderPane fx:id="contentArea" styleClass="main-content" />
    </center>

</BorderPane>