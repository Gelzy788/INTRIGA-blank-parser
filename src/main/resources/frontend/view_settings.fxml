<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.SettingsController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    
    <top>
        <VBox spacing="5.0" BorderPane.alignment="CENTER">
            <padding><Insets bottom="30.0" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Region prefHeight="30.0" prefWidth="4.0" styleClass="red-accent-line" />
                <Label styleClass="page-title" text="SYSTEM PREFERENCES" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="25.0" BorderPane.alignment="CENTER">
            
            <VBox spacing="20.0" styleClass="settings-card">
                <Label styleClass="settings-section-title" text="ДИРЕКТОРИИ ЭКСПОРТА" />
                
                <VBox spacing="8.0">
                    <Label styleClass="settings-label" text="ПУТЬ ДЛЯ EXCEL ОТЧЕТОВ (.xlsx)" />
                    <HBox spacing="10.0">
                        <TextField fx:id="excelPathField" editable="false" styleClass="path-field" text="C:\INTRIGA\Output\Excel" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnBrowseExcel" mnemonicParsing="false" styleClass="btn-outline" text="ОБЗОР" />
                    </HBox>
                </VBox>

                <VBox spacing="8.0">
                    <Label styleClass="settings-label" text="ПУТЬ ДЛЯ WORD ОТЧЕТОВ (.docx)" />
                    <HBox spacing="10.0">
                        <TextField fx:id="docxPathField" editable="false" styleClass="path-field" text="C:\INTRIGA\Output\Word" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnBrowseDocx" mnemonicParsing="false" styleClass="btn-outline" text="ОБЗОР" />
                    </HBox>
                </VBox>
            </VBox>

            <VBox spacing="20.0" styleClass="settings-card">
                <Label styleClass="settings-section-title" text="ВНЕШНИЙ ВИД ИНТЕРФЕЙСА" />
                
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <VBox spacing="5.0">
                        <Label styleClass="settings-label" text="ЦВЕТОВАЯ ТЕМА СИСТЕМЫ" />
                        <Label styleClass="stats-small-text" text="REQUIRES RESTART TO APPLY FULLY" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    
                    <HBox>
                        <Button fx:id="btnThemeLight" mnemonicParsing="false" styleClass="btn-toggle-left, btn-toggle-active" text="☀️ ДНЕВНАЯ" />
                        <Button fx:id="btnThemeDark" mnemonicParsing="false" styleClass="btn-toggle-right, btn-toggle-inactive" text="🌙 НОЧНАЯ" />
                    </HBox>
                </HBox>
            </VBox>
            
        </VBox>
    </center>
    </BorderPane>