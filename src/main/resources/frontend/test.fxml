<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="600.0" stylesheets="@test.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.InterfaceController">
    
    <top>
        <HBox alignment="TOP_RIGHT" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Button fx:id="settingsButton" mnemonicParsing="false" styleClass="settings-button" text="⚙" />
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="40.0" right="40.0" top="10.0" />
            </padding>
            
            <Label styleClass="title-label" text="Обработка PDF документов" />
            
            <Button fx:id="uploadButton" mnemonicParsing="false" styleClass="action-button" text="Выбрать PDF файлы..." />
            
            <Label fx:id="fileCountLabel" styleClass="info-label" text="Загружено файлов: 0" />
            
            <ListView fx:id="fileListView" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <Button fx:id="processButton" mnemonicParsing="false" styleClass="primary-button" text="Отправить на обработку" />
        </HBox>
    </bottom>

</BorderPane>
