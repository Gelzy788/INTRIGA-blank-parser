<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.QueueController">
    <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
    
    <top>
        <VBox spacing="5.0" BorderPane.alignment="CENTER">
            <padding><Insets bottom="20.0" /></padding>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Region prefHeight="30.0" prefWidth="4.0" styleClass="red-accent-line" />
                <Label styleClass="page-title" text="PDF PROCESSING ENGINE" />
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="30.0" BorderPane.alignment="CENTER">
            <VBox alignment="CENTER" spacing="15.0" styleClass="drag-drop-zone" HBox.hgrow="ALWAYS">
                <Label styleClass="pdf-icon-large" text="📄" />
                <Label styleClass="drag-title" text="ЗАГРУЗИТЕ ФАЙЛЫ" />
                
                <HBox alignment="CENTER" spacing="15.0">
                    <padding><Insets top="10.0" bottom="10.0"/></padding>
                    <Button fx:id="uploadButton" mnemonicParsing="false" styleClass="btn-dark" text="ВЫБРАТЬ ФАЙЛЫ" />
                    <Button fx:id="removeFileButton" mnemonicParsing="false" styleClass="btn-outline" text="УДАЛИТЬ ВЫБРАННЫЕ" />
                    <Button fx:id="clearListButton" mnemonicParsing="false" styleClass="btn-outline" text="ОЧИСТИТЬ СПИСОК" />
                </HBox>

                <ListView fx:id="fileListView" prefHeight="150.0" styleClass="custom-list-view" VBox.vgrow="ALWAYS" />
            </VBox>

            <VBox prefWidth="250.0" spacing="20.0">
                <VBox styleClass="stats-panel">
                    <Label styleClass="stats-title" text="ЗАГРУЖЕНО ФАЙЛОВ" />
                    <Label fx:id="fileCountLabel" styleClass="stats-value" text="0" />
                </VBox>
                </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" styleClass="bottom-action-bar" BorderPane.alignment="CENTER">
            <padding><Insets bottom="15.0" left="20.0" right="20.0" top="15.0" /></padding>
            <BorderPane.margin><Insets top="30.0" /></BorderPane.margin>
            
            <Label styleClass="status-badge" text="SYSTEM READY" />
            <Label styleClass="status-text" text="QUEUE_STATUS: EMPTY" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="processButton" mnemonicParsing="false" styleClass="btn-process-red" text="ОТПРАВИТЬ НА ОБРАБОТКУ (0) &gt;" />
        </HBox>
    </bottom>
</BorderPane>